# Server
PORT=4000
NODE_ENV=development

# Frontend origin (CORS + Better Auth trustedOrigins)
# Local:  http://localhost:3000
# Vercel: https://YOUR_PROJECT.vercel.app
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas (or local). Include the database name in the path.
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0

# Better Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace_with_long_random_secret_min_32_chars
# Must match the public frontend origin (Frontend Vercel URL)
# Example: https://propertyai-frontend.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave empty to disable Google login)
# Add production redirect URI in Google Cloud Console:
#   https://YOUR_FRONTEND.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional — without these, reset/verify/notification emails log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp Business API (optional — without these, messages log to console)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Rate limiting — 100 requests per 60 seconds per IP
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Gemini AI (optional — AI routes require this)
# GEMINI_API_KEY=
