# Server
PORT=4000
NODE_ENV=development

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:3000

# Rate limiting — 100 requests per 60 seconds per IP
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# MongoDB — connected in Database milestone
# MONGODB_URI=mongodb://localhost:27017/propertyai

# BetterAuth / JWT — configured in Authentication milestone
# BETTER_AUTH_SECRET=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Google OAuth — configured in Authentication milestone
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Gemini AI — configured in AI milestones
# GEMINI_API_KEY=
