# Server
PORT=4000
NODE_ENV=development

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas (or local). Include the database name in the path.
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0

# Rate limiting — 100 requests per 60 seconds per IP
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# BetterAuth / JWT — configured in Authentication milestone
# BETTER_AUTH_SECRET=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Google OAuth — configured in Authentication milestone
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Gemini AI — configured in AI milestones
# GEMINI_API_KEY=
