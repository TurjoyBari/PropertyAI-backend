# Server
PORT=4000
NODE_ENV=development

# Frontend origin (CORS + Better Auth trustedOrigins)
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas (or local). Include the database name in the path.
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propertyai?appName=Cluster0

# Better Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace_with_long_random_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:4000

# Google OAuth (optional — leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Rate limiting — 100 requests per 60 seconds per IP
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Gemini AI — configured in AI milestones
# GEMINI_API_KEY=
